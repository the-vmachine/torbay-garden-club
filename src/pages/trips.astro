---
import BaseLayout from '../layouts/BaseLayout.astro';

const trips = [
  {
    title: "Addenbrooke Gardens",
    date: "Thursday 23rd October 2025",
    location: "Bombay Hills",
    description: "Mark your calendars for a fun day out at Addenbrooke Gardens in the Bombay Hills. There will be lots of plants available for sale, and we'll be having lunch at Coffee Club, followed by more plant-buying options at Joy Plants.",
    registerUrl: "https://docs.google.com/forms/d/e/1FAIpQLSd1hSn_U-SuoDCWZEjE6R_r8OgDJhgD7p0cLMk5IRGFzrH1xQ/viewform",
    cover: "https://images.unsplash.com/photo-1585320806297-9794b3e4eeae?w=800&q=80",
    status: "upcoming"
  }
];
---
<BaseLayout title="Garden Trips" description="Register your interest for Torbay Garden Club trips and outings.">

  <div style="height: 64px;"></div>

  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Members</span>
      <h1 class="heading-display">Garden <em>Trips</em></h1>
      <p class="page-intro">Torbay Garden Club has regular trips for members. Register your interest below for upcoming outings.</p>
    </div>
  </section>

  <section class="trips-content">
    <div class="container">

      <div class="trips-list">
        {trips.map(trip => (
          <div class="trip-card">
            <div class="trip-image">
              <img src={trip.cover} alt={trip.title} />
              {trip.status === 'upcoming' && <span class="trip-badge">Upcoming</span>}
            </div>
            <div class="trip-details">
              <div class="trip-meta">
                <span class="trip-meta-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                  {trip.date}
                </span>
                <span class="trip-meta-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 21s-8-7.5-8-12a8 8 0 1 1 16 0c0 4.5-8 12-8 12z"/><circle cx="12" cy="9" r="2.5"/></svg>
                  {trip.location}
                </span>
              </div>
              <h2>{trip.title}</h2>
              <p>{trip.description}</p>
              <a href={trip.registerUrl} target="_blank" rel="noopener" class="btn-primary">Register Interest</a>
            </div>
          </div>
        ))}
      </div>

      <div class="trips-note">
        <div class="trips-note-inner">
          <h3>Planning More Trips</h3>
          <p>We organise garden visits and outings throughout the year. Details of upcoming trips are announced at monthly meetings and in the club newsletter. Keep an eye here for new additions.</p>
          <a href="/contact" class="link-arrow" style="display: inline-flex; margin-top: 0.5rem;">Get in touch →</a>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
.page-hero { padding: 4rem 0 0.5rem; }
.page-intro { max-width: 560px; color: var(--text-muted); margin-top: 1rem; font-size: 0.95rem; }
.trips-content { padding: 1.5rem 2rem 5rem; }
.trips-list { display: flex; flex-direction: column; gap: 2rem; margin-bottom: 4rem; }
.trip-card {
  display: grid;
  grid-template-columns: 380px 1fr;
  gap: 0;
  border: 1px solid var(--border);
  overflow: hidden;
  background: var(--white);
}
.trip-image { position: relative; }
.trip-image img { width: 100%; height: 100%; object-fit: cover; display: block; }
.trip-badge {
  position: absolute;
  top: 1rem; left: 1rem;
  background: var(--crimson);
  color: var(--white);
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.3rem 0.8rem;
}
.trip-details { padding: 2.5rem; display: flex; flex-direction: column; gap: 1rem; align-items: flex-start; }
.trip-meta { display: flex; flex-wrap: wrap; gap: 1.5rem; }
.trip-meta-item {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.82rem;
  color: var(--text-muted);
}
.trip-details h2 {
  font-family: var(--font-serif);
  font-size: 1.8rem;
  font-weight: 600;
  color: var(--charcoal);
  line-height: 1.2;
}
.trip-details p { font-size: 0.95rem; color: var(--text-muted); line-height: 1.7; }
.trips-note {
  background: var(--cream-dark);
  border: 1px solid var(--border);
  padding: 2.5rem;
  max-width: 640px;
}
.trips-note h3 {
  font-family: var(--font-serif);
  font-size: 1.2rem;
  font-weight: 600;
  margin-bottom: 0.75rem;
  color: var(--charcoal);
}
.trips-note p { font-size: 0.9rem; color: var(--text-muted); line-height: 1.7; }
@media (max-width: 768px) {
  .trip-card { grid-template-columns: 1fr; }
  .trip-image { height: 240px; }
}
</style>